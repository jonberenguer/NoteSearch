{
  "name": "notesearch",
  "version": "1.0.0",
  "description": "Fuzzy file search engine for notes and code snippets",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "download-fonts": "node download-fonts.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["notes", "search", "snippets", "fuzzy"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.notesearch.app",
    "productName": "NoteSearch",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "fonts/**/*",
      "download-fonts.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
